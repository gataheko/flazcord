<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 Accelerometer Sensor"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time X, Y, Z axis data"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp"/>

        <!-- Sensor availability status -->
        <TextView
            android:id="@+id/tvSensorStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking sensor..."
            android:textSize="14sp"
            android:textColor="#444444"
            android:padding="12dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="24dp"/>

        <!-- Axis readings card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Sensor Data"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvAxisX"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="X: -- m/s²"
                android:textSize="20sp"
                android:textColor="#E53935"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvAxisY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Y: -- m/s²"
                android:textSize="20sp"
                android:textColor="#43A047"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvAxisZ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Z: -- m/s²"
                android:textSize="20sp"
                android:textColor="#1E88E5"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Axis legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF9C4"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️ Axis Reference"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#5D4037"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X — Left/Right tilt\nY — Forward/Backward tilt\nZ — Face up/down + shake magnitude"
                android:textSize="12sp"
                android:textColor="#6D4C41"/>

        </LinearLayout>

        <!-- Shake detection section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shake Detection"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvShakeCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shakes detected: 0"
                android:textSize="18sp"
                android:textColor="#6A1B9A"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvShakeMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shake the device to see a message!"
                android:textSize="15sp"
                android:textColor="#555555"
                android:minHeight="48dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
